#!/usr/bin/env bash
set -euo pipefail

changed_toml=0
changed_lock=0

while IFS= read -r path; do
  if [[ "$path" == "Cargo.toml" ]]; then
    changed_toml=1
  fi
  if [[ "$path" == "Cargo.lock" ]]; then
    changed_lock=1
  fi
done < <(git diff --cached --name-only)

if [[ "$changed_toml" -eq 1 && "$changed_lock" -eq 0 ]]; then
  cat >&2 <<'EOF'
pre-commit: Cargo.toml is staged but Cargo.lock is not.

Run one of:
  cargo test
  cargo check

Then stage Cargo.lock and commit again.
EOF
  exit 1
fi
